#X obj 197 248 r bpm;
#X msg 140 207 1;
#X msg 103 207 0;
#X obj 102 72 s i-clock-on;
#X obj 102 50 r mpd-pad-8-master-clock;
#X obj 198 216 s i-mpd-pad-8-master-clock;
#X msg 248 196 set 1;
#X msg 198 196 set 0;
#X text 4 1 MASTER-CLOCK: VERSION 2, f 26;
#X text 99 30 RECEIVE CLOCK ON/OFF FROM MPD;
#X obj 128 121 nbx 3 20 0 600 0 0 bpm i-bpm BPM 50 10 0 13 #fcfcfc #000000 #000000 0 256;
#X obj 103 154 r clock-on;
#X text 257 143 SETTING MPD GUI STATE (USEFULT IF CLOCK IS TRUNED ON/OFF USING TOGGLE OBJECT), f 27;
#X obj 103 176 sel 0 1, f 11;
#X obj 103 341 pack f f;
#X obj 197 272 expr 4*(60000/$f1);
#X obj 197 321 t b f;
#X text 102 100 MASTER-CLOCK;
#X obj 103 367 outlet;
#X text 20 405 - CLOCK IS TOGGLED ON EITHER 1) THROUGH MPD GUI/DEVICE OR 2)MASTER CLOCK GUI \; - BPM IS UPDATED ALL THE TIME \; - CLOCK ON AND OFF IS SENT INSTANTLY \;, f 82;
#N canvas 458 140 500 246 PARAMETER-HANDLING 0;
#X obj 16 73 text set \$0-parameters 0 0;
#X obj 17 100 savestate;
#X obj 77 147 text sequence \$0-parameters;
#X msg 77 124 line 0 \, step;
#X obj 16 11 text define -k \$0-parameters;
#A set 60 \;;
#X obj 16 46 r bpm;
#X obj 17 183 s i-bpm;
#X connect 1 0 6 0;
#X connect 1 1 3 0;
#X connect 2 0 1 0;
#X connect 3 0 2 0;
#X connect 5 0 0 0;
#X restore 208 4 pd PARAMETER-HANDLING;
#X text 156 367 OUTLET [1]: CLOCK ON/OFF [2]: STANDARD-DURATION;
#X text 441 209 SATNDARD-DURATION: TRADITIONALLY BPM IS LENGTH OF EACH NOTE IN A 4/4 BAR. SO A STANDARD DURATION IS 4*NOTE-LENGTH. STANDARD DURATION NOT TO BE CONFUSED BY BAR-DURATION LATER DEFINED IN SIGNATURE PATCH. A BAR CAN HAVE MORE NOTES IN (LIKE 5/4), f 35;
