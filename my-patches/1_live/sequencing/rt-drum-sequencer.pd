#X obj 889 521 text sequence \$0-sequence, f 13;
#X obj 889 582 s \$0-REC-BAR-DUR;
#X floatatom 748 735 5 0 0 0 - - - 0;
#X obj 889 559 unpack f f;
#X text 393 481 SAVING BAR-DURATION WHEN RECORDING-QUEUE TRUNS ON MANUALLY, f 33;
#X text 1468 18 RECORDING PART \; ------------------------------------------------------------ \; IF RECORD QUEUE IS ON \, WHEN LAUNCH BANG ARRIVES \, TIMER WILL START RUNNING AND SEQUNCER WILL START RECORDING MIDI BANG AT ITS INLET AS WELL AS BANG FROM GUI. WITH EACH ARRIVING BANG THE TIMING OF THE BANG WILL BE INSERTED INTO \$0-SEQUNCE. IF NO NEW LAUNCH ARRIVES \, AFTER (BAR-DURATION+THRESHOLD) RECORDING OF MIDI WILL BE TURNED OFF BUT IT WILL STILL OUTPUT THE BANG FOR LISTENING PURPOSE., f 62;
#X text 1465 172 PLAYBACK PART \; ------------------------------------------------------------ \; WITH LAUNCH BANG ARRIVED \, TEXT SEQUNECE WILL OUTPUT THE BANGS WITH CORRECT TIMING. THIS PROCESS IS COMPLETELY SEPARATE BUT PARALLEL TO RECORDING (IF ACTIVE)., f 62;
#X text 593 763 ROOM FOR IMPROVEMENT \; ------------------------------------------------------------ \; CHANGE OF PLAYBACK SPEED (WHEN BAR DURATION CHANGES) IS DONE THROUGH: \; 1) READING ACTUAL BAR-DURATION (\$0-ACT-BAR-DUR) AS SOON AS RECORD-Q IS TURNED ON MANUALLY AND KEEPING IT ALWAYS AT THE TOP OF THE \$0-SEQUENCE TEXT --> \$0-REC-BAR-DUR. \; 2) WHEN SEQUENCER IS LAUNCHED \, \$0-REC-BAR-DUR IS READ FROM \$0-SEQUENCE AND PLAYBACK SPEED IS CHANGED BY SCALING DELAY TIME OF "TEXT SEQUENCE" STEPS WITH A SCALE OF ACTUAL/RECORDED BAR DURATION. \; ----> WORKS BUT I DONT LIKE THE LOGIC. ABSOLUTE-BAR-TIME SHOULD BE USED TO TRIGGER SAVED SEQUENCES IN TEXT-FILE (A COMPARISON FOR EXAMPLE OR == OBJECT) \;, f 62;
#X text 1464 276 NOTES: \; ------------------------------------------------------------ \; - DURATION OF THE SEQUNCER IS ONLY 1 BAR \; ------------------------------------------------------------ \; - IF \$0-SEQUNECE IS EMPTY (NOTHING RECORDED IN IT YET) \, WITH LAUNCH TEXT SEQUNCE WILL OUTPUT AN OUT OF RANGE ERROR. IT IS FINE. IGNORE IT \; ------------------------------------------------------------ \; - IF SORT RIGHT AFTER EVERY NEW MIDI RECORDED -> "TEXT SEQUENCE \$0-SEQUENCE" WILL LOSE COUNT OF WHAT IT IS OUTPUTTING WITH STEP MESSAGE -> SORT WITH A LAUNCH BANG AND EVEN IF COULD POSSIBLY MAKE MISTAKE FIRST TIME IF NEW MIDI IS VERY CLOSE TO THE BEGINNING OF THE BAR \, NEXT TIME WILL BE FINE \; ------------------------------------------------------------ \; - SYNCHRONIZATION IS MADE SURE WITH (RE)STARTING THE SEQUNCER USING THE LAUNCHER BANG \; ------------------------------------------------------------ \; - RECORD-QUEUE WILL ONLY BE TURNED-ON AND OFF MANUALLY \; ------------------------------------------------------------ \; - IF NEXT LAUNCH ARRIVES AT THE END OF BAR-DURATION \, THRESHOLD WILL NEVER REACH AND SO RECORDING WILL STAY ACTIVE. ------------------------------------------------------------ \; - VELOCITY INFO IF USING MPD IS NOT RECORDED SINCE NOT GOOD AT FINGER DRUMMING ANYWAYS \; ------------------------------------------------------------ \; - KEEP TEXT FILE CLOSED WHILE PLAYING OTHERWISE MIGHT EXPERIENCE LAGGING \; ------------------------------------------------------------ \;, f 62;
